[Unit]
Description=Uvjerenja Terminal
After=graphical.target network-online.target cups.service
Wants=network-online.target cups.service
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/opt/uvjerenja-terminal/src
EnvironmentFile=/etc/uvjerenja-terminal/uvjerenja-terminal.env
Environment=PYTHONUNBUFFERED=1
Environment=XAUTHORITY=/home/pi/.Xauthority
Environment=APP_ROOT=/opt/uvjerenja-terminal/src
Environment=PYTHON_BIN=/opt/uvjerenja-terminal/venv/bin/python
ExecStart=/usr/bin/env bash /opt/uvjerenja-terminal/src/scripts/launch_terminal.sh
Restart=always
RestartSec=3
TimeoutStartSec=90
TimeoutStopSec=20
KillSignal=SIGINT

[Install]
WantedBy=graphical.target
